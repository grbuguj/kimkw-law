# 이 파일을 복사해 .env.local 로 만들고 실제 키를 채우세요.
#   cp .env.example .env.local
# .env.local 은 깃에 올라가지 않습니다(.gitignore). 키를 절대 코드/깃에 넣지 마세요.
# 키를 바꾸면 dev 서버를 재시작해야 반영됩니다.

# === 무료 옵션 (둘 중 하나만 있어도 동작, 비교하려면 둘 다) ===

# Google Gemini — 무료, 카드 불필요
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — 무료, 카드 불필요
# 발급: https://console.groq.com/keys
GROQ_API_KEY=

# === 유료(선택) — 나중에 품질 최상으로 갈 때 ===
# Anthropic Claude — 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
